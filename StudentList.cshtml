@page
@model QuanLyTienDoSinhVien.Pages.Teacher.StudentListModel
@{
    ViewData["Title"] = "Danh sách Sinh viên";
}

@section Styles {
    <link rel="stylesheet" href="~/css/student-list.css" asp-append-version="true" />
}

@section Sidebar {
    <ul class="sidebar-menu">
        <li class="menu-item">
            <a href="/Student/Dashboard" class="menu-link active">
                <i class="fas fa-home menu-icon"></i>
                <span class="menu-text">Menu</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Teacher/StudentList" class="menu-link">
                <i class="fas fa-user menu-icon"></i>
                <span class="menu-text">Xem danh sách sinh viên</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Teacher/StudentProgress" class="menu-link">
                <i class="fas fa-book menu-icon"></i>
                <span class="menu-text">Theo dõi tiến độ sinh viên</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Progress" class="menu-link">
                <i class="fas fa-chart-line menu-icon"></i>
                <span class="menu-text">Tiến độ học tập</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Schedule" class="menu-link">
                <i class="fas fa-calendar menu-icon"></i>
                <span class="menu-text">Phê duyệt và góp ý lộ trình học tập</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Auth/Logout" class="menu-link">
                <i class="fas fa-sign-out-alt menu-icon"></i>
                <span class="menu-text">Đăng xuất</span>
            </a>
        </li>
    </ul>
}

<div class="student-page">

    <div class="page-header">
        <div>
            <h2>Danh sách Sinh viên</h2>
            <p>Quản lý thông tin và hồ sơ học tập của sinh viên.</p>
        </div>

        <div class="header-actions">
            @* <input type="text" placeholder="Tìm kiếm tên, email, mã SV..." class="table-search" /> *@
            <form method="get">
                <input type="text"
                       name="search"
                       value="@Request.Query["search"]"
                       placeholder="Tìm kiếm tên, email, mã SV..."
                       class="table-search" />
            </form>
            <button class="btn-filter">
                <i class="bi bi-funnel"></i> Bộ lọc
            </button>

            <button class="btn-add">
                + Thêm mới
            </button>
        </div>
    </div>

    <div class="table-card">

        <table class="student-table">
            <thead>
                <tr>
                    <th>Mã SV</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>SĐT</th>
                    <th>Địa chỉ</th>
                    <th>Lớp</th>
                    <th>Hành động</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td class="student-id">
                            <a href="#">@student.StudentCode</a>
                        </td>

                        <td class="student-info">
                            <div class="avatar">
                                @student.FullName.Substring(0,1)
                            </div>
                            <div>
                                <strong>@student.FullName</strong>
                                @* <div class="sub-info">
                                    @student.Gender - @student.BirthYear
                                </div> *@
                            </div>
                        </td>

                        <td>@student.Email</td>
                        <td>@student.Phone</td>
                        <td>@student.Address</td>

                        <td>
                            @if (student.Class != null)
                            {
                                <span class="badge-class">
                                    @student.Class.Name
                                </span>
                            }
                            else
                            {
                                <span class="badge-class">
                                    Chưa có lớp
                                </span>
                            }
                        </td>

                        @* <td>
                             @{
                                var classColor = student.ClassName.Contains("CNTT") ? "badge-cntt"
                                            : student.ClassName.Contains("QTKD") ? "badge-qtkd"
                                            : student.ClassName.Contains("KT") ? "badge-kt"
                                            : "badge-default";
                            }

                            <span class="badge-class @classColor">
                                @student.ClassName
                            </span>
                        </td> *@

                        <td class="actions">
                            <button class="icon-btn view">👁</button>
                            <button class="icon-btn edit">✏</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="pagination-box">

            <div class="pagination-info">
                Hiển thị 1-6 trong tổng 148 sinh viên
            </div>

            <div class="pagination-controls">
                <button class="page-btn">‹</button>
                <button class="page-number active">1</button>
                <button class="page-number">2</button>
                <button class="page-number">3</button>
<button class="page-btn">›</button>
            </div>

        </div>

    </div>

</div>