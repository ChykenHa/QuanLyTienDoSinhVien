@page
@model QuanLyTienDoSinhVien.Pages.Student.ProgressModel
@{
    ViewData["Title"] = "Progress Page";
    Layout = "~/Pages/Shared/_MainLayout.cshtml";
}

@section Sidebar {
    <ul class="sidebar-menu">
        <li class="menu-item">
            <a href="/Student/Dashboard" class="menu-link active">
                <i class="fas fa-home menu-icon"></i>
                <span class="menu-text">Menu</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Profile" class="menu-link">
                <i class="fas fa-user menu-icon"></i>
                <span class="menu-text">Sinh viên</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/StudyPlan" class="menu-link">
                <i class="fas fa-book menu-icon"></i>
                <span class="menu-text">Kế hoạch học tập</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Progress" class="menu-link">
                <i class="fas fa-chart-line menu-icon"></i>
                <span class="menu-text">Tiến độ học tập</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Schedule" class="menu-link">
                <i class="fas fa-calendar menu-icon"></i>
                <span class="menu-text">Lịch trình</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Auth/Logout" class="menu-link">
                <i class="fas fa-sign-out-alt menu-icon"></i>
                <span class="menu-text">Đăng xuất</span>
            </a>
        </li>
    </ul>
}

<link rel="stylesheet" href="~/css/progress.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

<!-- Chart.js for graphs -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

@* main-progress *@
<div class="progress-container">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-start mb-2">
        <div>
            <h1 class="display-5 fw-bold" style="color: #1e293b;">Tổng quan học tập</h1>
        </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">

        <!-- GPA -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon-box stat-icon-gpa">
                    <i class="fas fa-star"></i>
                </div>
                <div>
                    <p class="stat-label">GPA Trung bình</p>
                    <p class="stat-value">@Model.GPA.ToString("F2")</p>
                </div>
            </div>
        </div>

        <!-- Completion -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon-box stat-icon-completion">
                    <i class="fas fa-sync-alt"></i>
                </div>
                <div>
                    <p class="stat-label">Tỷ lệ hoàn thành</p>
                    <p class="stat-value">@Model.CompletionRate%</p>
                </div>
            </div>
        </div>

        <!-- Credits -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon-box stat-icon-credits">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div>
                    <p class="stat-label">Tín chỉ tích lũy</p>
                    <p class="stat-value">@Model.CumulativeCredits</p>
                </div>
            </div>
        </div>

        <!-- Rank -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon-box stat-icon-rank">
                    <i class="fas fa-trophy"></i>
                </div>
                <div>
                    <p class="stat-label">Xếp loại</p>
                    <p class="stat-value">@Model.StudentRank</p>
                </div>
            </div>
        </div>

    </div>

    <!-- CHARTS -->
    <div class="charts-row">
        <!-- GPA Trend Chart -->
        <div class="chart-panel">
            <h3>Xu hướng GPA theo kỳ học</h3>
            @if (Model.GPATrendData.Any())
            {
                <div class="chart-container">
                    <canvas id="gpaTrendChart"></canvas>
                </div>
            }
            else
            {
                <div style="padding: 24px; text-align: center; color: #64748b; background-color: #f8fafc; border-radius: 8px;">
                    Chưa có dữ liệu GPA để hiển thị
                </div>
            }
        </div>

        <!-- Grade Distribution Chart -->
        <div class="chart-panel">
            <h3>Phân bố điểm (Grade Distribution)</h3>
            @if (Model.GradeDistribution.Any(g => g.Count > 0))
            {
                <div class="chart-container">
                    <canvas id="gradeDistributionChart"></canvas>
                </div>
            }
            else
            {
                <div style="padding: 24px; text-align: center; color: #64748b; background-color: #f8fafc; border-radius: 8px;">
                    Chưa có dữ liệu điểm để hiển thị
                </div>
            }
        </div>
    </div>

    <div class="table-panel">
        <div class="table-panel-header">
            <h3>Tiến độ học tập chi tiết</h3>
            <div class="sort-buttons">
                <select class="form-select form-select-sm" style="width: auto; margin-right: 12px;" 
                        onchange="if(this.value) window.location.href='?sort=@Model.CurrentSortOrder&semester='+this.value; else window.location.href='?sort=@Model.CurrentSortOrder';">
                    <option value="">-- Tất cả kỳ học --</option>
                    @foreach (var semester in Model.AvailableSemesters)
                    {
                        @if (Model.SelectedSemesterId == semester.Id)
                        {
                            <option value="@semester.Id" selected>
                                @semester.Name
                                @if (semester.StartDate.HasValue)
                                {
                                    <span>(@semester.StartDate?.ToString("MM/yyyy"))</span>
                                }
                            </option>
                        }
                        else
                        {
                            <option value="@semester.Id">
                                @semester.Name
                                @if (semester.StartDate.HasValue)
                                {
                                    <span>(@semester.StartDate?.ToString("MM/yyyy"))</span>
                                }
                            </option>
                        }
                    }
                </select>
                <a href="?sort=desc@(Model.SelectedSemesterId.HasValue ? $"&semester={Model.SelectedSemesterId}" : "")" class="sort-btn @(Model.CurrentSortOrder == "desc" ? "active" : "")" title="Sắp xếp giảm dần theo điểm">
                    <span class="material-symbols-outlined">trending_down</span>
                </a>
                <a href="?sort=asc@(Model.SelectedSemesterId.HasValue ? $"&semester={Model.SelectedSemesterId}" : "")" class="sort-btn @(Model.CurrentSortOrder == "asc" ? "active" : "")" title="Sắp xếp tăng dần theo điểm">
                    <span class="material-symbols-outlined">trending_up</span>
                </a>
            </div>
        </div>

        <div class="table-panel-body">
            <table class="progress-table">
                <thead>
                    <tr>
                        <th>Khóa học</th>
                        <th>Enrollment ID</th>
                        <th>Giảng viên</th>
                        <th>Điểm số</th>
                        <th>Tiến độ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.EnrollmentDetails.Any())
                    {
                        @foreach (var enrollment in Model.EnrollmentDetails)
                        {
                            var progressPercent = enrollment.CompletionPercent ?? 0;
                            var colorMap = new[] { 
                                "#4f46e5", "#3b82f6", "#10b981", "#a855f7", "#f97316", "#ec4899", "#06b6d4", "#e11d48"
                            };
                            var colorIndex = Model.EnrollmentDetails.IndexOf(enrollment) % colorMap.Length;
                            var bgColor = colorMap[colorIndex];
                    <tr>
                        <td>
                            <div class="course-cell">
                                <div class="course-icon" style="background-color: @bgColor;">
                                    <span class="material-symbols-outlined">school</span>
                                </div>
                                <div class="course-info">
                                    <h6>@enrollment.SubjectName</h6>
                                    <p>@enrollment.SubjectCode - @enrollment.SemesterName</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div>
                                <span class="enrollment-id">#@enrollment.Id</span>
                                <p class="credits-info">@enrollment.Credits TC</p>
                            </div>
                        </td>
                        <td>
                            <div>
                                <p style="font-size: 13px; color: #334155; margin: 0;">@enrollment.LecturerNames</p>
                            </div>
                        </td>
                        <td>
                            <span class="score-value">
                                @if (enrollment.Score >= 0)
                                {
                                    @enrollment.Score.ToString("F1")
                                }
                                else
                                {
                                    <span style="color: #94a3b8;">N/A</span>
                                }
                            </span>
                            <span class="score-unit"> / 10</span>
                        </td>
                        <td>
                            <div class="progress-row">
                                <span class="progress-label">@enrollment.Status</span>
                                <span class="progress-percent" style="color: @bgColor;">@progressPercent%</span>
                            </div>
                            <div class="progress-bar-custom">
                                <div class="progress-bar-fill" style="background-color: @bgColor; width: @progressPercent%; box-shadow: 0 0 8px @bgColor;"></div>
                            </div>
                        </td>
                    </tr>
                        }
                    }
                    else
                    {
                    <tr>
                        <td colspan="5" style="padding: 24px; text-align: center; color: #64748b; background-color: #f8fafc;">
                            Không có dữ liệu enrollment
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Prepare data for charts
    @{
        // Prepare GPA Trend Data
        var gpaTrendLabels = string.Join(", ", Model.GPATrendData.Select(g => $"\"{g.SemesterName}\""));
        var gpaTrendValues = string.Join(", ", Model.GPATrendData.Select(g => g.GPA.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)));
        
        // Prepare Grade Distribution Data
        var gradeLabels = string.Join(", ", Model.GradeDistribution.Select(g => $"\"{g.Grade}\""));
        var gradeValues = string.Join(", ", Model.GradeDistribution.Select(g => g.Count));
        var gradeColors = string.Join(", ", Model.GradeDistribution.Select(g => $"\"{g.Color}\""));
    }

    // GPA Trend Chart
    @if (Model.GPATrendData.Any())
    {
        <text>
        var gpaTrendCtx = document.getElementById('gpaTrendChart');
        if (gpaTrendCtx) {
            new Chart(gpaTrendCtx, {
                type: 'line',
                data: {
                    labels: [@Html.Raw(gpaTrendLabels)],
                    datasets: [{
                        label: 'GPA Theo Kỳ',
                        data: [@Html.Raw(gpaTrendValues)],
                        borderColor: '#4f46e5',
                        backgroundColor: 'rgba(79, 70, 229, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 6,
                        pointBackgroundColor: '#4f46e5',
                        pointBorderColor: '#ffffff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            labels: {
                                font: { size: 13, family: "'Inter', sans-serif" },
                                color: '#64748b',
                                padding: 16
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 4,
                            ticks: {
                                font: { size: 12, family: "'Inter', sans-serif" },
                                color: '#94a3b8'
                            },
                            grid: {
                                color: '#e2e8f0',
                                drawBorder: false
                            }
                        },
                        x: {
                            ticks: {
                                font: { size: 12, family: "'Inter', sans-serif" },
                                color: '#94a3b8'
                            },
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        }
        </text>
    }

    // Grade Distribution Chart
    @if (Model.GradeDistribution.Any(g => g.Count > 0))
    {
        <text>
        var gradeCtx = document.getElementById('gradeDistributionChart');
        if (gradeCtx) {
            new Chart(gradeCtx, {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(gradeLabels)],
                    datasets: [{
                        label: 'Số Lượng Khóa Học',
                        data: [@Html.Raw(gradeValues)],
                        backgroundColor: [@Html.Raw(gradeColors)],
                        borderRadius: 8,
                        borderSkipped: false
                    }]
                },
                options: {
                    indexAxis: 'x',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            labels: {
                                font: { size: 13, family: "'Inter', sans-serif" },
                                color: '#64748b',
                                padding: 16
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                font: { size: 12, family: "'Inter', sans-serif" },
                                color: '#94a3b8',
                                stepSize: 1
                            },
                            grid: {
                                color: '#e2e8f0',
                                drawBorder: false
                            }
                        },
                        x: {
                            ticks: {
                                font: { size: 12, family: "'Inter', sans-serif" },
                                color: '#94a3b8'
                            },
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        }
        </text>
    }
</script>
