@page
@model QuanLyTienDoSinhVien.Pages.Teacher.NotificationsModel
@{ ViewData["Title"] = "Gửi thông báo"; Layout = "~/Pages/Shared/_MainLayout.cshtml"; }

@section Sidebar {
    <div class="sidebar-sticky">
        <div class="menu-section">
            <h6 class="sidebar-heading">GIẢNG VIÊN</h6>
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link menu-link" href="/Teacher/Dashboard"><span class="menu-icon"><i class="fas fa-clipboard-check"></i></span><span class="menu-text">Phê duyệt & Góp ý</span></a></li>
                <li class="nav-item"><a class="nav-link menu-link" href="/Teacher/Students"><span class="menu-icon"><i class="fas fa-users"></i></span><span class="menu-text">Danh sách sinh viên</span></a></li>
                <li class="nav-item"><a class="nav-link menu-link" href="/Teacher/Progress"><span class="menu-icon"><i class="fas fa-chart-line"></i></span><span class="menu-text">Theo dõi tiến độ</span></a></li>
                <li class="nav-item"><a class="nav-link menu-link active" href="/Teacher/Notifications"><span class="menu-icon"><i class="fas fa-bell"></i></span><span class="menu-text">Gửi thông báo</span></a></li>
                <li class="nav-item"><a class="nav-link menu-link" href="/Teacher/Evaluate"><span class="menu-icon"><i class="fas fa-star"></i></span><span class="menu-text">Đánh giá sinh viên</span></a></li>
                <li class="nav-item"><a class="nav-link menu-link" href="/Teacher/Assignments"><span class="menu-icon"><i class="fas fa-tasks"></i></span><span class="menu-text">Chấm điểm bài tập</span></a></li>
            </ul>
        </div>
        <div class="menu-section mt-3"><ul class="nav flex-column"><li class="nav-item"><a class="nav-link menu-link text-danger" href="/Auth/Logout"><span class="menu-icon"><i class="fas fa-sign-out-alt"></i></span><span class="menu-text">Đăng xuất</span></a></li></ul></div>
    </div>
}

<div class="page-header">
    <h2><i class="fas fa-bell"></i> Gửi thông báo nhắc nhở</h2>
    <p class="text-muted">Gửi thông báo đến sinh viên thuộc lớp phụ trách.</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div style="background-color: rgba(40,167,69,0.1); color: var(--success); padding: 15px 20px; border-radius: 10px; margin-bottom: 20px; border-left: 4px solid var(--success);"><i class="fas fa-check-circle"></i> @Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div style="background-color: rgba(220,53,69,0.1); color: var(--danger); padding: 15px 20px; border-radius: 10px; margin-bottom: 20px; border-left: 4px solid var(--danger);"><i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage</div>
}

<!-- Send Form -->
<div class="content-card">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-paper-plane"></i> Gửi thông báo mới</h3></div>
    <form method="post">
        <div style="margin-bottom: 20px;">
            <label style="font-weight: 600; margin-bottom: 8px; display: block;"><i class="fas fa-users"></i> Chọn sinh viên</label>
            <div style="display: flex; gap: 10px; margin-bottom: 10px;">
                <button type="button" class="btn btn-sm btn-outline" onclick="document.querySelectorAll('.sv-cb').forEach(c=>c.checked=true)"><i class="fas fa-check-double"></i> Chọn tất cả</button>
                <button type="button" class="btn btn-sm btn-outline" onclick="document.querySelectorAll('.sv-cb').forEach(c=>c.checked=false)"><i class="fas fa-times"></i> Bỏ chọn</button>
            </div>
            <div style="max-height: 250px; overflow-y: auto; border: 2px solid #E9ECEF; border-radius: 10px; padding: 15px;">
                @foreach (var s in Model.StudentOptions)
                {
                    <label style="display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid #f0f0f0; cursor: pointer;">
                        <input type="checkbox" name="studentUserIds" value="@s.UserId" class="sv-cb" style="width: 18px; height: 18px; accent-color: var(--primary-color);" />
                        <span>@s.DisplayName</span>
                    </label>
                }
            </div>
        </div>
        <div style="margin-bottom: 20px;">
            <label style="font-weight: 600; margin-bottom: 8px; display: block;"><i class="fas fa-envelope"></i> Nội dung thông báo</label>
            <textarea name="content" rows="4" required placeholder="Nhập nội dung thông báo nhắc nhở..."
                      style="width: 100%; padding: 12px 15px; border: 2px solid #E9ECEF; border-radius: 10px; font-size: 14px; resize: vertical;"></textarea>
        </div>
        <div style="text-align: right;">
            <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Gửi thông báo</button>
        </div>
    </form>
</div>

<!-- Sent History -->
<div class="content-card">
    <div class="card-header"><h3 class="card-title"><i class="fas fa-history"></i> Lịch sử thông báo gần đây</h3></div>
    @if (Model.SentNotifications.Any())
    {
        @foreach (var n in Model.SentNotifications)
        {
            <div style="background: var(--light-bg); padding: 12px 16px; border-radius: 10px; margin-bottom: 8px; border-left: 4px solid @(n.IsRead == true ? "#E9ECEF" : "var(--accent-color)");">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <small style="color: var(--text-light);"><i class="fas fa-clock"></i> @n.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                    <span class="badge @(n.IsRead == true ? "badge-success" : "badge-warning")">@(n.IsRead == true ? "Đã đọc" : "Chưa đọc")</span>
                </div>
                <p style="margin: 0; font-size: 14px;">@n.Content</p>
            </div>
        }
    }
    else
    {
        <p style="text-align: center; color: var(--text-light); padding: 20px;">Chưa có thông báo nào.</p>
    }
</div>
