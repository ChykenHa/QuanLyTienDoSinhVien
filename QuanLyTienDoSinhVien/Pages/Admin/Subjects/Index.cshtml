@page
@model QuanLyTienDoSinhVien.Pages.Admin.Subjects.IndexModel
@{
    ViewData["Title"] = "Quản Lý Môn Học";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2><i class="fas fa-book"></i> Quản Lý Môn Học</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-page="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Thêm Môn Học Mới
            </a>
            <a href="/Admin/Dashboard" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay Lại
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Danh Sách Môn Học (@Model.Subjects.Count)</h5>
        </div>
        <div class="card-body">
            @if (Model.Subjects.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Mã Môn</th>
                                <th>Tên Môn Học</th>
                                <th>Số Tín Chỉ</th>
                                <th>Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var subject in Model.Subjects)
                            {
                                <tr>
                                    <td>@subject.Id</td>
                                    <td><code>@subject.Code</code></td>
                                    <td><strong>@subject.Name</strong></td>
                                    <td><span class="badge bg-info">@subject.Credit</span></td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-page="Edit" asp-route-id="@subject.Id" class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-page="Delete" asp-route-id="@subject.Id" class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Chưa có môn học nào. Hãy thêm môn học mới.
                </div>
            }
        </div>
    </div>
</div>
