@page
@model QuanLyTienDoSinhVien.Pages.Admin.Lecturers.IndexModel
@{
    ViewData["Title"] = "Phân công giảng viên";
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
     <div class="alert alert-success"><i class="fas fa-check-circle"></i>
        @Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
     <div class="alert alert-danger"><i
            class="fas fa-exclamation-circle"></i> @Model.ErrorMessage</div>
}

<div class="container-fluid">
    <h2><i class="fas fa-chalkboard-teacher"></i> Phân công giảng viên cố vấn</h2>
    <p class="text-muted mb-4">Quản lý phân công giảng viên vào lớp và môn học.</p>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-plus-circle"></i> Thêm phân công</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Add" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Giảng viên</label>
                    <select name="lecturerId" class="form-select" required>
                        @foreach (var l in Model.AllLecturers)
                        {
                            <option value="@l.Id">@l.FullName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Môn học</label>
                    <select name="subjectId" class="form-select" required>
                        @foreach (var s in Model.AllSubjects)
                        {
                            <option value="@s.Id">@s.Code - @s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Lớp</label>
                    <select name="classId" class="form-select" required>
                        @foreach (var c in Model.AllClasses)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-success w-100"><i class="fas fa-plus"></i> Thêm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-list"></i> Danh sách phân công (@Model.Assignments.Count)</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Giảng viên</th>
                        <th>Email</th>
                        <th>Môn học</th>
                        <th>Lớp</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var idx = 1;
                    }
                    @foreach (var a in Model.Assignments)
                    {
                        <tr>
                            <td>@idx</td>
                            <td><strong>@a.Lecturer.FullName</strong></td>
                            <td>@a.Lecturer.Email</td>
                            <td>@a.Subject.Code - @a.Subject.Name</td>
                            <td><span class="badge bg-info">@a.Class.Name</span></td>
                            <td>
                                <form method="post" asp-page-handler="Delete" style="display: inline;">
                                    <input type="hidden" name="id" value="@a.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Xóa phân công này?')"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        idx++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
