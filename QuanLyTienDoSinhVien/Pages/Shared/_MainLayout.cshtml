@using System.Security.Claims

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Tiến Độ Sinh Viên</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    @{
        var userName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
        var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "Guest";
        var userInitials = string.Join("", userName.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : ""));
        if (string.IsNullOrEmpty(userInitials)) userInitials = "U";
    }

    <!-- Header -->
    <header class="main-header">
        <div class="header-content">
            <div class="logo-section">
                <div class="logo-icon">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div class="logo-text">
                    <h1>EduMetrics</h1>
                    <p>Hệ thống quản lý</p>
                </div>
            </div>

            <div class="header-search">
                <div class="search-box">
                    <input type="text" placeholder="Tìm kiếm chung..." />
                    <i class="fas fa-search search-icon"></i>
                </div>
            </div>

            <div class="header-actions">
                <div class="notification-icon">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </div>

                <div class="user-profile">
                    <div class="user-info">
                        <div class="user-avatar">@userInitials</div>
                        <div class="user-details">
                            <p class="user-name">@userName</p>
                            <p class="user-role">@userRole</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar">
        @if (User.IsInRole("Admin"))
        {
            <div class="sidebar-sticky">
                <div class="sidebar-menu-container">
                    <!-- General -->
                    <div class="menu-section">
                        <h6 class="sidebar-heading">CHUNG</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Dashboard") ? "active" : "")"
                                    href="/Admin/Dashboard">
                                    <span class="menu-icon"><i class="fas fa-home"></i></span>
                                    <span class="menu-text">Dashboard</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Management -->
                    <div class="menu-section">
                        <h6 class="sidebar-heading">QUẢN LÝ</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Users") ? "active" : "")"
                                    href="/Admin/Users/Index">
                                    <span class="menu-icon"><i class="fas fa-users"></i></span>
                                    <span class="menu-text">Người dùng</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Lecturers") ? "active" : "")"
                                    href="/Admin/Lecturers/Index">
                                    <span class="menu-icon"><i class="fas fa-chalkboard-teacher"></i></span>
                                    <span class="menu-text">Giảng viên</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Academic -->
                    <div class="menu-section">
                        <h6 class="sidebar-heading">ĐÀO TẠO</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Majors") ? "active" : "")"
                                    href="/Admin/Majors/Index">
                                    <span class="menu-icon"><i class="fas fa-university"></i></span>
                                    <span class="menu-text">Ngành học</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Classes") ? "active" : "")"
                                    href="/Admin/Classes/Index">
                                    <span class="menu-icon"><i class="fas fa-chalkboard"></i></span>
                                    <span class="menu-text">Lớp học</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Subjects") ? "active" : "")"
                                    href="/Admin/Subjects/Index">
                                    <span class="menu-icon"><i class="fas fa-book"></i></span>
                                    <span class="menu-text">Môn học</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Curriculum") ? "active" : "")"
                                    href="/Admin/Curriculum/Index">
                                    <span class="menu-icon"><i class="fas fa-graduation-cap"></i></span>
                                    <span class="menu-text">Chương trình đào tạo</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- System -->
                    <div class="menu-section">
                        <h6 class="sidebar-heading">HỆ THỐNG</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Configuration") ? "active" : "")"
                                    href="/Admin/Configuration/Index">
                                    <span class="menu-icon"><i class="fas fa-cogs"></i></span>
                                    <span class="menu-text">Cấu hình</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link menu-link @(Context.Request.Path.StartsWithSegments("/Admin/Reports") ? "active" : "")"
                                    href="/Admin/Reports/Index">
                                    <span class="menu-icon"><i class="fas fa-chart-bar"></i></span>
                                    <span class="menu-text">Báo cáo</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Logout -->
                    <div class="menu-section mt-3">
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link menu-link text-danger" href="/Auth/Logout">
                                    <span class="menu-icon"><i class="fas fa-sign-out-alt"></i></span>
                                    <span class="menu-text">Đăng xuất</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        }
        else
        {
            @RenderSection("Sidebar", required: false)
        }
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
