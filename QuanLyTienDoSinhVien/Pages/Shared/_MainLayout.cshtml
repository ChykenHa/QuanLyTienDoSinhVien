@using System.Security.Claims

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Tiến Độ Sinh Viên</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{ 
        var userName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
        var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "Guest";
        var userInitials = string.Join("", userName.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : ""));
        if (string.IsNullOrEmpty(userInitials)) userInitials = "U";
    }

    <!-- Header -->
    <header class="main-header">
        <div class="header-content">
            <div class="logo-section">
                <div class="logo-icon">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div class="logo-text">
                    <h1>EduMetrics</h1>
                    <p>Hệ thống quản lý</p>
                </div>
            </div>

            <div class="header-search">
                <div class="search-box">
                    <input type="text" placeholder="Tìm kiếm chung..." />
                    <i class="fas fa-search search-icon"></i>
                </div>
            </div>

            <div class="header-actions">
                <div class="notification-icon">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </div>

                <div class="user-profile">
                    <div class="user-info">
                        <div class="user-avatar">@userInitials</div>
                        <div class="user-details">
                            <p class="user-name">@userName</p>
                            <p class="user-role">@userRole</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar">
        @if (User.IsInRole("Admin"))
        {
            <div class="sidebar-sticky">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Dashboard") ? "active" : "")" href="/Admin/Dashboard">
                            <i class="fas fa-home"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Users") ? "active" : "")" href="/Admin/Users/Index">
                            <i class="fas fa-users"></i> Quản lý người dùng
                        </a>
                    </li>
                     <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Subjects") ? "active" : "")" href="/Admin/Subjects/Index">
                            <i class="fas fa-book"></i> Quản lý môn học
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Majors") ? "active" : "")" href="/Admin/Majors/Index">
                            <i class="fas fa-university"></i> Quản lý ngành
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Lecturers") ? "active" : "")" href="/Admin/Lecturers/Index">
                            <i class="fas fa-chalkboard-teacher"></i> Phân công giảng viên
                        </a>
                    </li>
                     <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Configuration") ? "active" : "")" href="/Admin/Configuration/Index">
                            <i class="fas fa-cogs"></i> Cấu hình hệ thống
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Reports") ? "active" : "")" href="/Admin/Reports/Index">
                            <i class="fas fa-chart-bar"></i> Báo cáo thống kê
                        </a>
                    </li>
                     <li class="nav-item mt-3">
                        <a class="nav-link text-danger" href="/Auth/Logout">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </a>
                    </li>
                </ul>
            </div>
        }
        else
        {
            @RenderSection("Sidebar", required: false)
        }
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
