@page
@model QuanLyTienDoSinhVien.Pages.Student.ProfileModel
@{
    ViewData["Title"] = "Profile Page";
    Layout = "~/Pages/Shared/_MainLayout.cshtml";
}


@section Sidebar {
    <ul class="sidebar-menu">
        <li class="menu-item">
            <a href="/Student/Dashboard" class="menu-link active">
                <i class="fas fa-home menu-icon"></i>
                <span class="menu-text">Menu</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Profile" class="menu-link">
                <i class="fas fa-user menu-icon"></i>
                <span class="menu-text">Sinh viên</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/StudyPlan" class="menu-link">
                <i class="fas fa-book menu-icon"></i>
                <span class="menu-text">Kế hoạch học tập</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Progress" class="menu-link">
                <i class="fas fa-chart-line menu-icon"></i>
                <span class="menu-text">Tiến độ học tập</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Student/Schedule" class="menu-link">
                <i class="fas fa-calendar menu-icon"></i>
                <span class="menu-text">Lịch trình</span>
            </a>
        </li>
        <li class="menu-item">
            <a href="/Auth/Logout" class="menu-link">
                <i class="fas fa-sign-out-alt menu-icon"></i>
                <span class="menu-text">Đăng xuất</span>
            </a>
        </li>
    </ul>
}

<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    corePlugins: {
      preflight: false
    }
  }
</script>


<div class="tw-profile bg-gradient-to-br from-blue-100 to-indigo-100 min-h-screen p-10">

    <!-- HEADER -->
    <div class="flex justify-between items-start mb-10">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">Student Profile</h1>
            <p class="text-slate-600 mt-2">Manage academic profile and settings.</p>
        </div>

        <div class="flex gap-6">
            <!-- Attendance -->
            <div class="bg-white px-6 py-4 rounded-2xl shadow">
                <p class="text-xs text-slate-400 tracking-wider">ATTENDANCE</p>
                <div class="flex items-center gap-2 mt-1">
                    <span class="text-2xl font-bold">@Model.AttendanceRate%</span>
                </div>
            </div>

            <!-- GPA -->
            <div class="bg-white px-6 py-4 rounded-2xl shadow">
                <p class="text-xs text-slate-400 tracking-wider">CURRENT GPA</p>
                <div class="flex items-end gap-1 mt-1">
                    <span class="text-3xl font-bold text-blue-600">
                        @Model.GPA.ToString("F2")
                    </span>
                    <span class="text-slate-400 text-sm">/ 4.0</span>
                </div>
            </div>
        </div>
    </div>

    <!-- CARD -->
    <div class="bg-white rounded-3xl shadow-xl p-10 grid grid-cols-[320px_1fr] gap-10">

        <!-- LEFT -->
        <div class="flex flex-col items-center text-center">

            <div class="relative">
                <img src="https://thumbs.dreamstime.com/b/student-icon-vector-graduation-mortar-board-school-college-university-glyph-pictogram-male-person-profile-avatar-108392101.jpg?w=768"
                     class="w-44 h-44 rounded-3xl border-4 border-blue-400 object-cover" />

                <span class="absolute bottom-3 right-3 w-4 h-4 bg-green-500 border-2 border-white rounded-full"></span>
            </div>

            <h2 class="text-xl font-bold mt-5">@Model.FullName</h2>

            <span class="mt-2 text-sm text-slate-500 bg-slate-100 px-4 py-1 rounded-full">
                ID: @Model.StudentCode
            </span>

            <button class="mt-8 w-full py-3 rounded-xl bg-blue-500 text-white font-semibold hover:bg-blue-600 transition">
                ✏️ Edit Profile
            </button>

            <button class="mt-3 w-full py-3 rounded-xl border border-slate-300 text-slate-600 hover:bg-slate-100 transition">
                🔗 Share Profile
            </button>
        </div>

        <!-- RIGHT -->
        <div>

            <!-- PERSONAL -->
            <div class="mb-10">
                <div class="flex items-center gap-3 mb-4">
                    <span class="p-2 bg-blue-100 text-blue-600 rounded-lg">👤</span>
                    <h3 class="font-bold tracking-wider text-slate-600">PERSONAL INFORMATION</h3>
                </div>

                <div class="grid grid-cols-2 gap-x-10 gap-y-6">
                    <div>
                        <p class="text-xs text-slate-400">EMAIL ADDRESS</p>
                        <p class="font-semibold">@Model.Email</p>
                    </div>

                    <div>
                        <p class="text-xs text-slate-400">PHONE NUMBER</p>
                        <p class="font-semibold">@Model.Phone</p>
                    </div>

                    <div class="col-span-2">
                        <p class="text-xs text-slate-400">RESIDENTIAL ADDRESS</p>
                        <p class="font-semibold">@Model.Address</p>
                    </div>
                </div>
            </div>

            <!-- ACADEMIC -->
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <span class="p-2 bg-indigo-100 text-indigo-600 rounded-lg">🎓</span>
                    <h3 class="font-bold tracking-wider text-slate-600">ACADEMIC DETAILS</h3>
                </div>

                <div class="grid grid-cols-2 gap-x-10 gap-y-6">
                    <div>
                        <p class="text-xs text-slate-400">CLASS ID / NAME</p>
                        <p class="font-semibold">@Model.Class</p>
                    </div>

                    <div>
                        <p class="text-xs text-slate-400">MAJOR</p>
                        <p class="font-semibold">@Model.MajorName</p>
                    </div>

                    <div>
                        <p class="text-xs text-slate-400">ACADEMIC YEAR</p>
                        <p class="font-semibold">@Model.AcademicYear</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <p class="text-xs text-slate-400">PROFILE VISIBILITY</p>
                        <input type="checkbox" class="scale-125 accent-blue-500"
                               @(Model.IsPrivate== true ? "" : "checked") />
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>